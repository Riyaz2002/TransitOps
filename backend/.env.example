# Local PostgreSQL example. Never commit a real .env file or production secrets.
DATABASE_URL=postgresql+psycopg://transitops:change-me@localhost:5432/transitops

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret-of-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Keep false locally over HTTP. Set true in HTTPS production deployments.
REFRESH_TOKEN_COOKIE_SECURE=false

# Set false in development if your local database does not use TLS.
# AWS RDS typically requires true when its SSL/TLS enforcement is enabled.
DB_SSL_REQUIRED=false
ENVIRONMENT=development
